{
  "name": "voice-command-center",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p console/tsconfig.json --noEmit && vite build --config console/vite.config.ts",
    "dev": "tsx src/server.ts",
    "eval": "tsx scripts/run-eval.ts",
    "schema": "tsx scripts/export-schemas.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ws": "^8.21.1",
    "zod": "^4.4.3"
  }
}
