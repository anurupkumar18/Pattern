# Secrets — never commit credentials of any kind
.env
.env.*
*.pem
*.key
**/apikeys*
**/credentials*
# Native credential-management source is code, never a credential value.
!macos/VoiceOps/Credentials/
!macos/VoiceOps/Credentials/*.swift

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/
.ruff_cache/
*.egg-info/

# Swift / Xcode
.build/
build/
DerivedData/
*.xcuserstate
xcuserdata/
.swiftpm/

# Ephemeral task evidence — task-scoped captures are never committed
captures/
evidence/tmp/
evals/reports/*.json
evals/reports/*.html
!evals/reports/latest.json

# OS
.DS_Store
